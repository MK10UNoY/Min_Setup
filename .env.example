# ============================================================
# Low Setup Guru — Environment Configuration
# ============================================================
# Copy this file to .env and adjust values as needed.
#
# LOCAL DEVELOPMENT (default):
#   Just run `docker-compose up -d` and these defaults work.
#
# PRODUCTION:
#   Uncomment the production lines below and fill in values.
# ============================================================

# --- Judge0 Connection ---
# Local: Judge0 running via docker-compose on your machine
JUDGE0_URL=http://localhost:2358

# Production: Your VPS running Judge0
# JUDGE0_URL=https://judge.yourdomain.com

# --- Authentication ---
# Local: Leave empty (no auth needed locally)
JUDGE0_TOKEN=

# Production: Basic auth token for your Judge0 instance
# JUDGE0_TOKEN=your_basic_auth_token_here

# --- Rate Limiting ---
# Local: Disable for faster development
RATE_LIMIT_ENABLED=false

# Production: Enable to prevent abuse
# RATE_LIMIT_ENABLED=true
